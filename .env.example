# Google Places API (minimum for reading reviews)
GOOGLE_PLACES_API_KEY=your_places_api_key
PLACE_ID=your_google_place_id

# Google Business Profile OAuth (required to publish replies)
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GBP_ACCOUNT_ID=your_gbp_account_id
GBP_LOCATION_ID=your_gbp_location_id

# Business info
BUSINESS_NAME=Your Business Name

# Low-rating email alerts (optional)
ALERT_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
