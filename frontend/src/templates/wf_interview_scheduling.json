    {"id":"n6","type":"workflowNode","position":{"x":300,"y":600},"data":{"label":"Send Reminder","type":"webhook","config":{"url":"https://your-mail.com/send","method":"POST","body":"{\"template\":\"interview_reminder\"}"},"status":"idle"}}
