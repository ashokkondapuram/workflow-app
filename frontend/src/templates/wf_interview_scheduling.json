{
  "id": "wf_interview_scheduling",
  "name": "Interview Scheduling Bot",
  "description": "Candidate applies → HR gets notified → Calendar invite sent → Reminder 1hr before",
  "category": "HR",
  "nodes": [
    {"id":"n1","type":"workflowNode","position":{"x":300,"y":50},"data":{"label":"Application Received","type":"trigger","config":{"method":"POST","path":"/apply"},"status":"idle"}},
    {"id":"n2","type":"workflowNode","position":{"x":300,"y":160},"data":{"label":"Notify HR Team","type":"webhook","config":{"url":"https://hooks.slack.com/hr-channel","method":"POST","body":"{\"text\":\"New application received!\"}"},"status":"idle"}},
    {"id":"n3","type":"workflowNode","position":{"x":300,"y":270},"data":{"label":"Create Calendar Event","type":"action","config":{"url":"https://www.googleapis.com/calendar/v3/calendars/primary/events","method":"POST"},"status":"idle"}},
    {"id":"n4","type":"workflowNode","position":{"x":300,"y":380},"data":{"label":"Send Confirmation Email","type":"webhook","config":{"url":"https://your-mail.com/send","method":"POST","body":"{\"template\":\"interview_confirmation\"}"},"status":"idle"}},
